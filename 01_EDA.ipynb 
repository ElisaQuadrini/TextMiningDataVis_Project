    "### 3.3 Text Cleaning"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "bb9ee8da",
   "metadata": {},
   "source": [
    "We normalize whitespace in questions, contexts and answers by stripping leading/trailing spaces \n",
    "and collapsing multiple consecutive spaces into one. \n",
    "After cleaning, all length features are recomputed to reflect the normalized text."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 821,
   "id": "4dac5b98",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Text cleaning complete — lengths recomputed.\n"
     ]
    }
   ],
   "source": [
    "# Normalize whitespace: strip edges and collapse multiple spaces\n",
    "def clean_text(s):\n",
    "    s = str(s).strip()\n",
    "    s = re.sub(r'\\s+', ' ', s)\n",
    "    return s\n",
    "\n",
    "train_df['question'] = train_df['question'].map(clean_text)\n",
    "train_df['context']  = train_df['context'].map(clean_text)\n",
    "\n",
    "if 'answer_text' in train_df.columns:\n",
    "    train_df['answer_text'] = train_df['answer_text'].map(clean_text)\n",
    "\n",
    "# Recompute length features after cleaning\n",
    "train_df['q_len_char'] = train_df['question'].str.len()\n",
    "train_df['q_len_tok']  = train_df['question'].str.split().str.len()\n",
    "train_df['c_len_char'] = train_df['context'].str.len()\n",
    "train_df['c_len_tok']  = train_df['context'].str.split().str.len()\n",
    "\n",
    "print('Text cleaning complete — lengths recomputed.')"
   ]
  },
