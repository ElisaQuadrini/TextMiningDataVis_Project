    "    vals_d,\n",
    "    color='#0891B2',   # cyan\n",
    "    edgecolor='white',\n",
    "    linewidth=0.7\n",
    ")\n",
    "\n",
    "# Percentage labels\n",
    "for bar, v in zip(bars, vals_d):\n",
    "    ax.text(\n",
    "        bar.get_width() + bar.get_width()*0.02,\n",
    "        bar.get_y() + bar.get_height()/2,\n",
    "        f'{v/total_d:.1%}',\n",
    "        va='center',\n",
